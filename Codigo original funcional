                const montoRaw = pedido.total_orden || pedido['Total Orden'] || pedido['Total Orden '] || pedido.Total_Orden || pedido.monto || 0;
                const montoNumerico = String(montoRaw).replace(/[^0-9.,]/g, '').replace(',', '.');
